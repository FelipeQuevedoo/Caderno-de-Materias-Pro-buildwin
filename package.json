{
  "name": "caderno-portatil",
  "private": false,
  "version": "1.0.0",
  "description": "Caderno de materias portatil para Windows (React + Electron).",
  "author": "Equipe Caderno Portatil",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.mjs",
    "dev:desktop": "concurrently -k \"npm:dev\" \"npm:dev:electron\"",
    "start": "electron electron/main.mjs",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "pack:portable": "npm run build && electron-builder --config electron-builder.json --win portable",
    "pack:win": "npm run build && electron-builder --config electron-builder.json --win portable nsis",
    "pack:win:installer": "npm run build && electron-builder --config electron-builder.json --win nsis"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-ordered-list": "^3.20.4",
    "@tiptap/extension-list-item": "^3.20.4",
    "@tiptap/extension-bullet-list": "^3.20.4",
    "@tiptap/extension-font-family": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-subscript": "^3.20.4",
    "@tiptap/extension-superscript": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-text-align": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "clsx": "2.1.1",
    "concurrently": "^9.2.1",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "3.4.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0",
    "wait-on": "^9.0.3"
  }
}
